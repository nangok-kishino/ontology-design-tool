# Azure Cosmos DB
# Azure ポータルの Cosmos DB アカウント → キー から取得
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-primary-key-here
COSMOS_DATABASE_ID=ontology-db

# Azure Static Web Apps 認証（Azureデプロイ時のみ必要）
# Azure ポータルの アプリの登録 から取得
# ローカル開発時は SWA CLI が認証をエミュレートするため不要
AAD_CLIENT_ID=your-client-id-here
AAD_CLIENT_SECRET=your-client-secret-here
